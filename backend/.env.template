# Environment variables for live-translation-app
# Copy this file to .env and fill in the values

# Required for the application
HOST_IP=your_host_ip

# Public domain name (optional). If set, Stripe success/cancel URLs and other
# public-facing links will use https://<DOMAIN>. Falls back to https://<HOST_IP>
# if DOMAIN is not set.
DOMAIN=

# For HTTPS (optional, for automatic SSL certificates)
# Uncomment and set for automatic SSL certificates when port is externally available
# HTTPS_EMAIL=your-email@example.com

# ICE Servers for WebRTC NAT traversal (comma-separated)
# Default: Google STUN server + local coturn TURN server
# The coturn service runs in the docker-compose stack
ICE_SERVERS=stun:stun.l.google.com:19302,turn:127.0.0.1:3478

# Local coturn TURN server credentials (must match docker-compose.yml)
TURN_SERVER=turn:127.0.0.1:3478
TURN_USERNAME=turn_user
TURN_PASSWORD=your_turn_password

# Stripe payment configuration (required for subscription payments)
# Get these from your Stripe dashboard (https://dashboard.stripe.com/test/apikeys)
# STRIPE_SECRET_KEY: Your Stripe secret key (sk_test_... for testing, sk_live_... for production)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# STRIPE_WEBHOOK_SECRET: Your Stripe webhook secret (whsec_...) for verifying webhook signatures
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe price IDs for subscription tiers
# Create these in your Stripe dashboard under Products > Prices
# These should match the price IDs you created for each subscription tier
# Example format: price_1H5NyF2eZvKYlo2C6j2bK9Df
STRIPE_PRICE_STARTER=price_1StarterID_here
STRIPE_PRICE_PRO=price_1ProID_here
STRIPE_PRICE_ENTERPRISE=price_1EnterpriseID_here

# Stripe API version and retry configuration
STRIPE_API_VERSION=2024-12-18.acacia
STRIPE_MAX_RETRIES=2

# Stripe Checkout URLs (for redirect after payment)
# If left as relative paths, they will be prefixed with https://DOMAIN or
# https://HOST_IP automatically. Override with absolute URLs if needed.
STRIPE_SUCCESS_URL=/api/v1/billing/success
STRIPE_CANCEL_URL=/api/v1/billing/cancel

# x402 v2 crypto payment configuration
# FACILITATOR_URL: Coinbase facilitator URL (use x402.org for testnet, CDP for production)
FACILITATOR_URL=https://x402.org/facilitator
# PLATFORM_WALLET: Your EVM wallet address for receiving x402 payments
PLATFORM_WALLET=0xYourPlatformWallet
# SOLANA_WALLET: Your Solana wallet address (optional, falls back to PLATFORM_WALLET)
SOLANA_WALLET=0xYourSolanaWallet

# CDP facilitator configuration (recommended for production)
# Sign up at https://cdp.coinbase.com and generate API credentials
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Supabase configuration (required for database and auth)
# Get these from your Supabase project settings
SUPABASE_URL=your_supabase_url
# SUPABASE_SECRET_KEY: Service role key — required for backend server-side operations (bypasses RLS)
# NEVER expose this key to the browser/frontend
SUPABASE_SECRET_KEY=your_supabase_secret_key
# SUPABASE_PUBLISHABLE_KEY: Anon/publishable key — for frontend client-side use only (enforces RLS)
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# VLLM configuration (for the transcription/translation models)
# VLLM_API_KEY=your_vllm_api_key  # If your VLLM instance requires authentication
# VLLM_MODEL=your_model_name      # Optional: specify model to use

# Livepeer configuration (for compute providers)
# LIVEPEER_API_KEY=your_livepeer_api_key  # Optional: if using Livepeer for video transcoding