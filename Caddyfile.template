{$HOST_IP}.sslip.io

tls internal

# Reverse proxy for the live translation app
reverse_proxy /whip* {
    to http://backend:8000
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
}

reverse_proxy /ws* {
    to http://backend:8000
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
}

# Serve the frontend static files
root * /frontend/dist
file_server

# Proxy to VLLM if needed for direct access (optional)
reverse_proxy /v1/* {
    to http://vllm:8001
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
}