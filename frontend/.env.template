# Supabase configuration (required for all authentication methods)
# Get these from your Supabase project settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY: The public publishable key (enforces RLS)
# NEVER use the secret/service role key in the frontend
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# ─── Auth provider setup (Supabase Dashboard) ──────────────────────────────
# The following providers must be enabled in the Supabase Dashboard under
# Authentication → Providers. No additional frontend env vars are needed —
# the Supabase client handles provider routing automatically.
#
# Email/Password:
#   Enabled by default. Confirm email settings under Authentication → Email.
#
# Google OAuth:
#   1. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
#   2. Add authorized redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
#   3. Enable in Dashboard → Authentication → Providers → Google
#   4. Paste Client ID and Client Secret
#
# Twitter/X OAuth:
#   1. Create app at https://developer.twitter.com/en/portal/dashboard
#   2. Set callback URL: https://<project-ref>.supabase.co/auth/v1/callback
#   3. Enable in Dashboard → Authentication → Providers → Twitter
#   4. Paste Client ID and Client Secret
#
# Web3 Wallet (SIWE):
#   Enable in Dashboard → Authentication → Providers → Web3 Wallet
#   See supabase/migrations/20260415_01_enable_web3_auth.sql for details

# ─── Payment configuration ──────────────────────────────────────────────────
# Stripe public key for Checkout (frontend only, safe to expose)
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here