# Environment variables for live-translation-app
# Copy this file to .env and fill in the values

# Required for the application
HOST_IP=your_host_ip

# For HTTPS (optional, for automatic SSL certificates)
# Uncomment and set for automatic SSL certificates when port is externally available
# HTTPS_EMAIL=your-email@example.com

# VLLM configuration (for the transcription/translation models)
# VLLM_API_KEY=your_vllm_api_key  # If your VLLM instance requires authentication
# VLLM_MODEL=your_model_name      # Optional: specify model to use
