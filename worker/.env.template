# Worker Configuration
# Copy this file to worker/.env and fill in the values

# Worker server port
WORKER_PORT=9935

# VLLM WebSocket configuration (for the transcription/translation models)
VLLM_WS_URL=ws://localhost:8080/v1/realtime
VLLM_SOURCE_LANG=en
VLLM_TARGET_LANG=es

# Orchestrator Registration Configuration
# Set to "false" to disable periodic registration with the orchestrator
REGISTRATION_ENABLED=true
# Registration interval in seconds (default: 60)
REGISTRATION_INTERVAL=60

# Orchestrator base URL (e.g., http://orchestrator:8000)
ORCH_SERVICE_ADDR=

# Secret used to authenticate with the orchestrator
ORCH_SECRET=

# Capability identification
CAPABILITY_NAME=live-translation-worker
CAPABILITY_URL=https://localhost:9935
CAPABILITY_DESCRIPTION=Live translation worker

# Capability pricing and capacity
CAPABILITY_CAPACITY=1
CAPABILITY_PRICE_PER_UNIT=0
CAPABILITY_PRICE_SCALING=1
