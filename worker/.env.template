# Worker Configuration
# Copy this file to worker/.env and fill in the values

#comma separated list of GPUs
REALTIME_GPUS=0
REALTIME_GPU_MEMORY_UTILIZATION=0.65
WORKER_GPUS=1

# Gemma translation runtime
GEMMA_VLLM_MODEL=cyankiwi/gemma-4-E4B-it-AWQ-INT4
GEMMA_VLLM_PORT=6100
GEMMA_VLLM_GPUS=1
GEMMA_VLLM_GPU_MEMORY_UTILIZATION=0.55
GEMMA_VLLM_MAX_MODEL_LEN=16384
GEMMA_VLLM_BASE_URL=http://gemma-vllm:6100

# Worker server port
WORKER_PORT=9935

# VLLM WebSocket configuration (for the transcription/translation models)
VLLM_WS_URL=ws://vllm:6000/v1/realtime
VLLM_SOURCE_LANG=en
VLLM_TARGET_LANG=es

# Orchestrator Registration Configuration
# Set to "false" to disable periodic registration with the orchestrator
REGISTRATION_ENABLED=true
# Registration interval in seconds (default: 600)
REGISTRATION_INTERVAL=600

# Orchestrator base URL (e.g., http://orchestrator:8000)
ORCH_SERVICE_ADDR=

# Secret used to authenticate with the orchestrator
ORCH_SECRET=

# Capability identification (REQUIRED - no defaults)
CAPABILITY_URL=https://localhost:9935

# live-transcribe capability pricing and capacity
LIVE_CAPABILITY_CAPACITY=1
LIVE_CAPABILITY_PRICE_PER_UNIT=1
LIVE_CAPABILITY_PRICE_SCALING=1
