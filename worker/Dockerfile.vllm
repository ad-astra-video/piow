FROM vllm/vllm-openai:latest

# Install curl for healthcheck
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Install uv
RUN pip install --no-cache-dir uv

# Install required packages using uv
RUN uv pip install --system soxr librosa soundfile

# Upgrade transformers to v5
RUN uv pip install --system --upgrade transformers

# Copy and run the vLLM WebSocket patch script
COPY patch_vllm.py /patch_vllm.py
RUN python3 /patch_vllm.py && rm /patch_vllm.py